<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Thêm cây - PlantCare Reminder</title>
  <link rel="stylesheet" href="/css/app.css" />
</head>
<body>
  <div class="navbar">
    <a class="brand" href="/">PlantCare Reminder</a>

    <div>
      <a href="/">Home</a>
      <a href="/logout">Đăng xuất</a>
    </div>
  </div>

  <div class="container">
    <div class="card">
      <h1>Thêm cây mới</h1>

      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>

      <form action="/plants/create" method="POST" enctype="multipart/form-data">
        <div class="form-group">
          <label>Tên cây</label>
          <input
            type="text"
            name="name"
            placeholder="Ví dụ: Sen đá"
            value="<%= oldData.name || '' %>"
          />
        </div>

        <div class="form-group">
          <label>Loại cây</label>
          <input
            type="text"
            name="type"
            placeholder="Ví dụ: Cây cảnh, cây để bàn"
            value="<%= oldData.type || '' %>"
          />
        </div>

        <div class="form-group">
          <label>Vị trí đặt cây</label>
          <input
            type="text"
            name="location"
            placeholder="Ví dụ: Ban công, phòng khách, bàn học..."
            value="<%= oldData.location || '' %>"
          />
        </div>

        <div class="form-group">
          <label>Ảnh cây</label>
          <input type="file" name="image" accept="image/*" />
        </div>

        <div class="form-group">
          <label>Số lần tưới trong một ngày tưới</label>
          <input
            type="number"
            name="wateringTimesPerDay"
            min="1"
            value="<%= oldData.wateringTimesPerDay || 1 %>"
          />
        </div>

        <div class="form-group">
          <label>Số ngày tưới</label>
          <input
            type="number"
            name="wateringIntervalDays"
            min="1"
            value="<%= oldData.wateringIntervalDays || 1 %>"
          />
          <small>Ví dụ: nhập 2 nghĩa là 2 ngày mới tưới 1 lần.</small>
        </div>

        <div class="form-group">
          <label>Ngày bắt đầu tưới / ngày cần tưới tiếp</label>
          <input
            type="date"
            name="nextWateringAt"
            value="<%= oldData.nextWateringAt || new Date().toISOString().slice(0, 10) %>"
          />
        </div>

        <div class="form-group">
          <label>Mô tả</label>
          <textarea name="description" placeholder="Mô tả ngắn về cây"><%= oldData.description || '' %></textarea>
        </div>

        <div class="form-group">
          <label>Ghi chú chăm sóc</label>
          <textarea name="note" placeholder="Ví dụ: Để nơi có ánh sáng nhẹ"><%= oldData.note || '' %></textarea>
        </div>

        <div class="actions">
          <button class="btn btn-primary" type="submit">Lưu cây</button>
          <a class="btn btn-light" href="/">Quay lại</a>
        </div>
      </form>
    </div>
  </div>
</body>
</html>