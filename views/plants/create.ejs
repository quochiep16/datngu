<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Thêm cây - PlantCare Reminder</title>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #f3f8f3;
    }

    .navbar {
      background: #2e7d32;
      color: white;
      padding: 16px 40px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .navbar a {
      color: white;
      text-decoration: none;
      font-weight: bold;
      margin-left: 16px;
    }

    .container {
      max-width: 750px;
      margin: 35px auto;
      padding: 0 20px;
    }

    .card {
      background: white;
      padding: 30px;
      border-radius: 16px;
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
    }

    h1 {
      color: #2e7d32;
      margin-top: 0;
    }

    .form-group {
      margin-bottom: 18px;
    }

    label {
      display: block;
      margin-bottom: 7px;
      font-weight: bold;
      color: #333;
    }

    input,
    textarea {
      width: 100%;
      box-sizing: border-box;
      padding: 12px;
      border: 1px solid #ddd;
      border-radius: 10px;
      font-size: 15px;
      font-family: Arial, sans-serif;
    }

    textarea {
      min-height: 90px;
      resize: vertical;
    }

    input:focus,
    textarea:focus {
      outline: none;
      border-color: #2e7d32;
    }

    .error {
      background: #ffebee;
      color: #c62828;
      padding: 12px;
      border-radius: 10px;
      margin-bottom: 18px;
    }

    .actions {
      display: flex;
      gap: 10px;
      margin-top: 20px;
    }

    .btn {
      padding: 12px 18px;
      border-radius: 10px;
      border: none;
      cursor: pointer;
      font-weight: bold;
      text-decoration: none;
      font-size: 15px;
    }

    .btn-primary {
      background: #2e7d32;
      color: white;
    }

    .btn-light {
      background: #e8f5e9;
      color: #2e7d32;
    }
  </style>
</head>
<body>
  <div class="navbar">
    <div>PlantCare Reminder</div>
    <div>
      <a href="/dashboard">Dashboard</a>
      <a href="/plants">Cây trồng</a>
      <a href="/logout">Đăng xuất</a>
    </div>
  </div>

  <div class="container">
    <div class="card">
      <h1>Thêm cây mới</h1>

      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>

      <form action="/plants/create" method="POST">
        <div class="form-group">
          <label>Tên cây</label>
          <input
            type="text"
            name="name"
            placeholder="Ví dụ: Sen đá, Trầu bà, Xương rồng..."
            value="<%= oldData.name || '' %>"
          />
        </div>

        <div class="form-group">
          <label>Loại cây</label>
          <input
            type="text"
            name="type"
            placeholder="Ví dụ: Cây cảnh, cây để bàn..."
            value="<%= oldData.type || '' %>"
          />
        </div>

        <div class="form-group">
          <label>Tần suất tưới</label>
          <input
            type="number"
            name="wateringFrequency"
            min="1"
            placeholder="Ví dụ: 2 nghĩa là 2 ngày tưới 1 lần"
            value="<%= oldData.wateringFrequency || 1 %>"
          />
        </div>

        <div class="form-group">
          <label>Ngày tưới gần nhất</label>
          <input
            type="date"
            name="lastWateredAt"
            value="<%= oldData.lastWateredAt || new Date().toISOString().slice(0, 10) %>"
          />
        </div>

        <div class="form-group">
          <label>Mô tả</label>
          <textarea
            name="description"
            placeholder="Mô tả ngắn về cây"
          ><%= oldData.description || '' %></textarea>
        </div>

        <div class="form-group">
          <label>Ghi chú chăm sóc</label>
          <textarea
            name="note"
            placeholder="Ví dụ: Không tưới quá nhiều nước, để nơi có ánh sáng..."
          ><%= oldData.note || '' %></textarea>
        </div>

        <div class="actions">
          <button class="btn btn-primary" type="submit">Lưu cây</button>
          <a class="btn btn-light" href="/plants">Quay lại</a>
        </div>
      </form>
    </div>
  </div>
</body>
</html>