<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Chi tiết cây - PlantCare Reminder</title>
  <link rel="stylesheet" href="/css/app.css" />
</head>
<body>
  <div class="navbar">
    <a class="brand" href="/">PlantCare Reminder</a>

    <div>
      <a href="/">Home</a>
      <a href="/plants/create">+ Thêm cây mới</a>
      <a href="/logout">Đăng xuất</a>
    </div>
  </div>

  <div class="container">
    <div class="card">
      <% if (plant.image) { %>
        <img class="plant-image-detail" src="<%= plant.image %>" alt="<%= plant.name %>" />
      <% } else { %>
        <div class="image-placeholder">Chưa có ảnh</div>
      <% } %>

      <div class="status <%= plant.statusClass %>">
        <%= plant.statusText %>
      </div>

      <h1><%= plant.name %></h1>

      <div class="meta">
        <div>Loại cây: <%= plant.type || "Chưa nhập" %></div>

        <div>
          Lịch tưới:
          <%= plant.wateringTimesPerDay %> lần /
          <%= plant.wateringIntervalDays %> ngày
        </div>

        <div>
          Hôm nay đã tưới:
          <span class="water-count">
            <%= plant.wateredTodayCount %>/<%= plant.requiredTodayCount %>
          </span>
        </div>

        <div>
          Lần tưới gần nhất:
          <%= formatDateTime(plant.lastWateredAt) %>
        </div>

        <div>
          Ngày cần tưới tiếp:
          <%= formatDate(plant.nextWateringAt) %>
        </div>
      </div>

      <div class="box">
        <h3>Mô tả</h3>
        <p><%= plant.description || "Chưa có mô tả" %></p>
      </div>

      <div class="note-highlight">
        <h3>Ghi chú chăm sóc</h3>
        <p><%= plant.note || "Chưa có ghi chú" %></p>
      </div>

      <div class="box">
        <h3>Lịch sử tưới gần đây</h3>

        <% if (!plant.wateringLogs || plant.wateringLogs.length === 0) { %>
          <p>Chưa có lịch sử tưới.</p>
        <% } else { %>
          <ul>
            <% plant.wateringLogs.slice().reverse().slice(0, 10).forEach((log) => { %>
              <li><%= formatDateTime(log.wateredAt) %></li>
            <% }) %>
          </ul>
        <% } %>
      </div>

      <div class="actions">
        <a class="btn btn-light" href="/">Quay lại Home</a>
        <a class="btn btn-primary" href="/plants/<%= plant._id %>/edit">Sửa cây</a>

        <form action="/plants/<%= plant._id %>/watered" method="POST">
          <button class="btn btn-water" type="submit">
            Đã tưới (<%= plant.wateredTodayCount %>/<%= plant.requiredTodayCount %>)
          </button>
        </form>

        <form
          action="/plants/<%= plant._id %>/delete"
          method="POST"
          onsubmit="return confirm('Bạn có chắc muốn xóa cây này không?')"
        >
          <button class="btn btn-danger" type="submit">Xóa cây</button>
        </form>
      </div>
    </div>
  </div>
</body>
</html>