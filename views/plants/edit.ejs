<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Sửa cây - PlantCare Reminder</title>
  <link rel="stylesheet" href="/css/app.css" />
</head>
<body>
  <div class="navbar">
    <a class="brand" href="/">PlantCare Reminder</a>

    <div>
      <a href="/">Home</a>
      <a href="/logout">Đăng xuất</a>
    </div>
  </div>

  <div class="container">
    <div class="card">
      <h1>Sửa cây</h1>

      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>

      <form action="/plants/<%= plant._id %>/edit" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="oldImage" value="<%= plant.image || '' %>" />

        <div class="form-group">
          <label>Tên cây</label>
          <input type="text" name="name" value="<%= plant.name || '' %>" />
        </div>

        <div class="form-group">
          <label>Loại cây</label>
          <input type="text" name="type" value="<%= plant.type || '' %>" />
        </div>

        <div class="form-group">
          <label>Vị trí đặt cây</label>
          <input
            type="text"
            name="location"
            value="<%= plant.location || '' %>"
            placeholder="Ví dụ: Ban công, phòng khách, bàn học..."
          />
        </div>

        <div class="form-group">
          <label>Ảnh hiện tại</label>

          <% if (plant.image) { %>
            <img class="current-image" src="<%= plant.image %>" alt="<%= plant.name %>" />
          <% } else { %>
            <p>Chưa có ảnh</p>
          <% } %>

          <input type="file" name="image" accept="image/*" />
        </div>

        <div class="form-group">
          <label>Số lần tưới trong một ngày tưới</label>
          <input
            type="number"
            name="wateringTimesPerDay"
            min="1"
            value="<%= plant.wateringTimesPerDay || 1 %>"
          />
        </div>

        <div class="form-group">
          <label>Số ngày tưới</label>
          <input
            type="number"
            name="wateringIntervalDays"
            min="1"
            value="<%= plant.wateringIntervalDays || 1 %>"
          />
        </div>

        <div class="form-group">
          <label>Ngày cần tưới tiếp</label>
          <input
            type="date"
            name="nextWateringAt"
            value="<%= formatDateInput(plant.nextWateringAt) %>"
          />
        </div>

        <div class="form-group">
          <label>Mô tả</label>
          <textarea name="description"><%= plant.description || '' %></textarea>
        </div>

        <div class="form-group">
          <label>Ghi chú chăm sóc</label>
          <textarea name="note"><%= plant.note || '' %></textarea>
        </div>

        <div class="actions">
          <button class="btn btn-primary" type="submit">Cập nhật</button>
          <a class="btn btn-light" href="/plants/<%= plant._id %>">Quay lại</a>
        </div>
      </form>
    </div>
  </div>
</body>
</html>