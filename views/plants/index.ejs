<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Danh sách cây - PlantCare Reminder</title>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #f3f8f3;
    }

    .navbar {
      background: #2e7d32;
      color: white;
      padding: 16px 40px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .navbar a {
      color: white;
      text-decoration: none;
      font-weight: bold;
      margin-left: 16px;
    }

    .container {
      max-width: 1100px;
      margin: 35px auto;
      padding: 0 20px;
    }

    .top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 25px;
    }

    h1 {
      color: #2e7d32;
      margin: 0;
    }

    .btn {
      display: inline-block;
      padding: 10px 16px;
      border-radius: 10px;
      text-decoration: none;
      border: none;
      cursor: pointer;
      font-weight: bold;
      font-size: 14px;
    }

    .btn-primary {
      background: #2e7d32;
      color: white;
    }

    .btn-light {
      background: #e8f5e9;
      color: #2e7d32;
    }

    .btn-danger {
      background: #c62828;
      color: white;
    }

    .btn-water {
      background: #0288d1;
      color: white;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }

    .card {
      background: white;
      border-radius: 16px;
      padding: 22px;
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
    }

    .card h2 {
      margin-top: 0;
      color: #2e7d32;
    }

    .meta {
      color: #555;
      line-height: 1.7;
      margin-bottom: 16px;
    }

    .actions {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 15px;
    }

    .actions form {
      margin: 0;
    }

    .status {
      display: inline-block;
      padding: 7px 12px;
      border-radius: 999px;
      font-weight: bold;
      font-size: 13px;
      margin-bottom: 12px;
    }

    .status-overdue {
      background: #ffebee;
      color: #c62828;
    }

    .status-today {
      background: #fff8e1;
      color: #ef6c00;
    }

    .status-upcoming {
      background: #e8f5e9;
      color: #2e7d32;
    }

    .status-unknown {
      background: #eeeeee;
      color: #555;
    }

    .empty {
      background: white;
      padding: 35px;
      text-align: center;
      border-radius: 16px;
      color: #666;
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
    }

    @media (max-width: 900px) {
      .grid {
        grid-template-columns: 1fr;
      }

      .top {
        flex-direction: column;
        align-items: flex-start;
        gap: 15px;
      }
    }
  </style>
</head>
<body>
  <div class="navbar">
    <div>PlantCare Reminder</div>
    <div>
      <a href="/dashboard">Dashboard</a>
      <a href="/plants">Cây trồng</a>
      <a href="/logout">Đăng xuất</a>
    </div>
  </div>

  <div class="container">
    <div class="top">
      <h1>Danh sách cây trồng</h1>
      <a class="btn btn-primary" href="/plants/create">+ Thêm cây mới</a>
    </div>

    <% if (plants.length === 0) { %>
      <div class="empty">
        <h2>Chưa có cây nào</h2>
        <p>Hãy thêm cây đầu tiên để bắt đầu theo dõi lịch tưới.</p>
        <a class="btn btn-primary" href="/plants/create">Thêm cây ngay</a>
      </div>
    <% } else { %>
      <div class="grid">
        <% plants.forEach((plant) => { %>
          <div class="card">
            <div class="status <%= plant.statusClass %>">
              <%= plant.statusText %>
            </div>

            <h2><%= plant.name %></h2>

            <div class="meta">
              <div>Loại cây: <%= plant.type || "Chưa nhập" %></div>
              <div>Tần suất tưới: <%= plant.wateringFrequency %> ngày/lần</div>
              <div>Lần tưới gần nhất: <%= formatDate(plant.lastWateredAt) %></div>
              <div>Ngày tưới tiếp theo: <%= formatDate(plant.nextWateringAt) %></div>
            </div>

            <div class="actions">
              <a class="btn btn-light" href="/plants/<%= plant._id %>">Chi tiết</a>
              <a class="btn btn-light" href="/plants/<%= plant._id %>/edit">Sửa</a>

              <form action="/plants/<%= plant._id %>/watered" method="POST">
                <button class="btn btn-water" type="submit">Đã tưới</button>
              </form>

              <form
                action="/plants/<%= plant._id %>/delete"
                method="POST"
                onsubmit="return confirm('Bạn có chắc muốn xóa cây này không?')"
              >
                <button class="btn btn-danger" type="submit">Xóa</button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</body>
</html>