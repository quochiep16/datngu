<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Đăng nhập - PlantCare Reminder</title>
  <link rel="stylesheet" href="/css/app.css" />
</head>
<body class="auth-body">
  <div class="auth-box">
    <a class="auth-brand" href="/">PlantCare Reminder</a>

    <h1>Đăng nhập</h1>
    <div class="auth-desc">Đăng nhập để quản lý lịch tưới cây</div>

    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>

    <form action="/login" method="POST">
      <div class="form-group">
        <label>Email</label>
        <input
          type="email"
          name="email"
          placeholder="Nhập email"
          value="<%= oldData.email || '' %>"
        />
      </div>

      <div class="form-group">
        <label>Mật khẩu</label>
        <input
          type="password"
          name="password"
          placeholder="Nhập mật khẩu"
        />
      </div>

      <button class="btn btn-primary" style="width: 100%;" type="submit">
        Đăng nhập
      </button>
    </form>

    <div class="link">
      Chưa có tài khoản?
      <a href="/register">Đăng ký</a>
    </div>
  </div>
</body>
</html>